{{/* ────────────────────────────────────────────────────────────────────────
     Age encryption
     ──────────────────────────────────────────────────────────────────────── */}}
{{- $ageKeyFile := joinPath .chezmoi.homeDir ".config/chezmoi/key.txt" -}}
{{- $hasKey     := stat $ageKeyFile -}}
{{- $ageIdentity := "" -}}
{{- if not $hasKey -}}
{{-   $ageIdentity = promptStringOnce . "ageIdentity" "Age private key (AGE-SECRET-KEY-1..., leave empty to skip — encrypted files will not sync)" -}}
{{- end -}}

{{- if or $hasKey (ne $ageIdentity "") }}
encryption = "age"

[age]
    identity  = "~/.config/chezmoi/key.txt"
    recipient = "age1v8qcrm9f47g3nwjfxxcm5hc78a3xnpp6szf6cy9vrwfkzrefapfqa0krlv"
{{ end -}}

{{/* ────────────────────────────────────────────────────────────────────────
     Tool selection
     Answers are stored in chezmoi.toml[data] and used by:
       - run_once_before_10-install-tools.sh.tmpl  (install)
       - .chezmoiignore.tmpl                        (skip unselected configs)
     To install a previously skipped tool: edit chezmoi.toml and set the
     relevant bool to true, then run: chezmoi apply
     ──────────────────────────────────────────────────────────────────────── */}}
{{- $installZsh        := promptBoolOnce . "installZsh"        "Install zsh + oh-my-zsh + p10k"                       true  -}}
{{- $installShellTools := promptBoolOnce . "installShellTools" "Install shell tools (fzf / zoxide / bat / eza)" true  -}}
{{- $installHtop       := promptBoolOnce . "installHtop"       "Install htop"                                         true  -}}
{{- $installMise       := promptBoolOnce . "installMise"       "Install mise (tool version manager)"                  true  -}}
{{- $installTmux       := promptBoolOnce . "installTmux"       "Install tmux"                                         true  -}}
{{- $installLazygit    := promptBoolOnce . "installLazygit"    "Install lazygit"                                      false -}}
{{- $installNeovim     := promptBoolOnce . "installNeovim"     "Install neovim + ripgrep + fd-find"                   false -}}
{{- $installUv         := promptBoolOnce . "installUv"         "Install uv (Python package manager)"                  false -}}
{{- $installRanger     := promptBoolOnce . "installRanger"     "Install ranger (file manager)"                        false -}}
{{- $installSops       := promptBoolOnce . "installSops"       "Install sops"                                         false -}}
{{- $installWezterm    := promptBoolOnce . "installWezterm"    "Install wezterm (macOS only)"                         false -}}
{{- $installKarabiner  := promptBoolOnce . "installKarabiner"  "Install karabiner-elements (macOS only)"              false -}}

[data]
    ageIdentity       = {{ $ageIdentity       | quote }}
    installZsh        = {{ $installZsh }}
    installShellTools = {{ $installShellTools }}
    installHtop       = {{ $installHtop }}
    installMise       = {{ $installMise }}
    installTmux       = {{ $installTmux }}
    installLazygit    = {{ $installLazygit }}
    installNeovim     = {{ $installNeovim }}
    installUv         = {{ $installUv }}
    installRanger     = {{ $installRanger }}
    installSops       = {{ $installSops }}
    installWezterm    = {{ $installWezterm }}
    installKarabiner  = {{ $installKarabiner }}
