#!/bin/bash
# Install prerequisite binaries required by subsequent scripts:
#   - curl      : download binaries from GitHub Releases
#   - wget      : needed by eza Debian install (apt key fetch)
#   - gpg       : needed by eza Debian install (dearmor key)
#   - age       : chezmoi encryption; must exist before run_once_before_01 writes key.txt
#   - git       : version control (required by many tools)
#   - git-delta : improved git diff pager
set -euo pipefail

_install_age_binary() {
    local version
    version=$(curl -fsSLI -o /dev/null -w '%{url_effective}' \
        https://github.com/FiloSottile/age/releases/latest \
        | sed 's|.*/tag/v||')
    [[ -n "$version" ]] || { echo "❌ Could not determine age version" >&2; exit 1; }
    local arch
    case "$(uname -m)" in
        x86_64)  arch="amd64" ;;
        aarch64|arm64) arch="arm64" ;;
        *) echo "❌ Unsupported arch: $(uname -m)" >&2; exit 1 ;;
    esac
    local tmp
    tmp=$(mktemp /tmp/age-XXXXXX.tar.gz)
    curl -fsSL "https://github.com/FiloSottile/age/releases/download/v${version}/age-v${version}-linux-${arch}.tar.gz" -o "$tmp"
    tar -xz -C /tmp -f "$tmp"
    sudo install -m 755 /tmp/age/age /usr/local/bin/age
    sudo install -m 755 /tmp/age/age-keygen /usr/local/bin/age-keygen
    rm -rf /tmp/age "$tmp"
}

_install_delta_binary() {
    local ver
    ver=$(curl -fsSLI -o /dev/null -w '%{url_effective}' \
        https://github.com/dandavison/delta/releases/latest \
        | sed 's|.*/tag/||')
    [[ -n "$ver" ]] || { echo "❌ Could not determine delta version" >&2; exit 1; }
    local arch
    arch=$(uname -m)
    local tmp
    tmp=$(mktemp /tmp/delta-XXXXXX.tar.gz)
    curl -fsSL "https://github.com/dandavison/delta/releases/download/${ver}/delta-${ver}-${arch}-unknown-linux-musl.tar.gz" -o "$tmp"
    tar -xz -C /tmp -f "$tmp"
    sudo install -m 755 /tmp/delta-*/delta /usr/local/bin/delta
    rm -rf /tmp/delta-*/ "$tmp"
}

{{- if eq .chezmoi.os "darwin" }}

# ── macOS ─────────────────────────────────────────────────────────────────────
if ! command -v brew &>/dev/null; then
    echo "❌ Homebrew not found. Install it first: https://brew.sh" >&2
    exit 1
fi

command -v curl  &>/dev/null || brew install curl
command -v wget  &>/dev/null || brew install wget
command -v gpg   &>/dev/null || brew install gnupg
command -v age   &>/dev/null || brew install age
command -v git   &>/dev/null || brew install git
command -v delta &>/dev/null || brew install git-delta

{{- else if eq .chezmoi.os "linux" }}

# ── Linux ─────────────────────────────────────────────────────────────────────
{{-   $id     := .chezmoi.osRelease.id | default "" }}
{{-   $idLike := get .chezmoi.osRelease "id_like" | default "" }}
{{-   $isDebian := or (eq $id "debian") (eq $id "ubuntu") (contains "debian" $idLike) (contains "ubuntu" $idLike) }}
{{-   $isRhel   := or (eq $id "fedora") (eq $id "rhel") (eq $id "centos") (eq $id "rocky") (eq $id "almalinux") (contains "rhel" $idLike) (contains "fedora" $idLike) }}

{{-   if $isDebian }}
_needs_update=false
command -v curl &>/dev/null || _needs_update=true
command -v wget &>/dev/null || _needs_update=true
command -v gpg  &>/dev/null || _needs_update=true
command -v git  &>/dev/null || _needs_update=true
if [ "$_needs_update" = "true" ]; then
    sudo apt-get update -qq
    command -v curl &>/dev/null || sudo apt-get install -y curl
    command -v wget &>/dev/null || sudo apt-get install -y wget
    command -v gpg  &>/dev/null || sudo apt-get install -y gnupg
    command -v git  &>/dev/null || sudo apt-get install -y git
fi

if command -v age &>/dev/null; then
    echo "✅ age already installed: $(age --version)"
else
    echo "📦 Installing age..."
    if apt-cache show age &>/dev/null 2>&1; then
        sudo apt-get install -y age
    else
        _install_age_binary
    fi
fi

if ! command -v delta &>/dev/null; then
    echo "📦 Installing git-delta..."
    if apt-cache show git-delta &>/dev/null 2>&1; then
        sudo apt-get install -y git-delta
    else
        _install_delta_binary
    fi
fi

{{-   else if $isRhel }}
command -v curl &>/dev/null || sudo dnf install -y curl
command -v wget &>/dev/null || sudo dnf install -y wget
command -v gpg  &>/dev/null || sudo dnf install -y gnupg2
command -v git  &>/dev/null || sudo dnf install -y git

if command -v age &>/dev/null; then
    echo "✅ age already installed: $(age --version)"
else
    echo "📦 Installing age..."
    if dnf list age &>/dev/null 2>&1; then
        sudo dnf install -y age
    elif yum list age &>/dev/null 2>&1; then
        sudo yum install -y age
    else
        _install_age_binary
    fi
fi

if ! command -v delta &>/dev/null; then
    echo "📦 Installing git-delta..."
    if dnf list git-delta &>/dev/null 2>&1; then
        sudo dnf install -y git-delta
    else
        _install_delta_binary
    fi
fi

{{-   else }}
if ! command -v age &>/dev/null; then
    echo "📦 Installing age..."
    _install_age_binary
fi
{{-   end }}

{{- end }}

echo "✅ Prerequisites ready (curl / wget / gpg / age / git / git-delta)"
