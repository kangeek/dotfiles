#!/bin/bash
# Install selected tools. Idempotent — skips tools that are already installed.
# To install a previously skipped tool:
#   1. Edit ~/.config/chezmoi/chezmoi.toml and set the tool's flag to true
#   2. Run: chezmoi apply
set -euo pipefail

# ── Detect OS / package manager ───────────────────────────────────────────────
OS="{{ .chezmoi.os }}"
{{- if eq .chezmoi.os "linux" }}
{{-   $id     := .chezmoi.osRelease.id | default "" }}
{{-   $idLike := get .chezmoi.osRelease "id_like" | default "" }}
{{-   $isDebian := or (eq $id "debian") (eq $id "ubuntu") (contains "debian" $idLike) (contains "ubuntu" $idLike) }}
{{-   $isRhel   := or (eq $id "fedora") (eq $id "rhel") (eq $id "centos") (eq $id "rocky") (eq $id "almalinux") (contains "rhel" $idLike) (contains "fedora" $idLike) }}
IS_DEBIAN={{ $isDebian }}
IS_RHEL={{ $isRhel }}
{{- else }}
IS_DEBIAN=false
IS_RHEL=false
{{- end }}

# ── Helpers ───────────────────────────────────────────────────────────────────
has() { command -v "$1" &>/dev/null; }
skip() { echo "✅ $1 already installed — skipping"; }

# Resolve the latest release version via the redirect URL — no API call, no rate limit.
# Usage: gh_latest owner/repo          → e.g. "0.44.1"  (v-prefix stripped)
gh_latest() {
    curl -fsSLI -o /dev/null -w '%{url_effective}' \
        "https://github.com/$1/releases/latest" \
        | sed 's|.*/tag/v\?||'
}

pkg_install() {
    # Usage: pkg_install <brew-pkg> <apt-pkg> <dnf-pkg>
    local brew_pkg="$1" apt_pkg="$2" dnf_pkg="$3"
    if [ "$OS" = "darwin" ]; then
        brew install "$brew_pkg"
    elif [ "$IS_DEBIAN" = "true" ]; then
        sudo apt-get install -y "$apt_pkg"
    elif [ "$IS_RHEL" = "true" ]; then
        sudo dnf install -y "$dnf_pkg"
    fi
}

# Ensure EPEL is available on RHEL-family systems — many tools (htop,
# ripgrep, fd-find, bat, fzf, zoxide, ranger, age …) live there.
if [ "$IS_RHEL" = "true" ]; then
    sudo dnf install -y epel-release 2>/dev/null || true
fi

# Update package index once
_pkg_updated=false
pkg_update() {
    if [ "$_pkg_updated" = "false" ]; then
        if [ "$IS_DEBIAN" = "true" ]; then sudo apt-get update -qq; fi
        _pkg_updated=true
    fi
}

# ── zsh + oh-my-zsh + p10k ────────────────────────────────────────────────────
{{ if .installZsh -}}
echo "── zsh ──"
has zsh && skip zsh || { pkg_update; pkg_install zsh zsh zsh; }
if [ -d "$HOME/.oh-my-zsh" ]; then
    skip oh-my-zsh
else
    echo "📦 Installing oh-my-zsh..."
    RUNZSH=no CHSH=no KEEP_ZSHRC=yes sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)"
    sudo chsh -s "$(command -v zsh)" "$USER"
fi
{{ end -}}

# ── shell tools (fzf / zoxide / bat / eza) ───────────────────────────────────
{{ if .installShellTools -}}
echo "── shell tools ──"

# fzf
if has fzf; then
    skip fzf
elif [ "$OS" = "darwin" ]; then
    brew install fzf
else
    _ver=$(gh_latest junegunn/fzf)
    _arch=$(uname -m | sed 's/x86_64/amd64/;s/aarch64/arm64/')
    _tmp=$(mktemp /tmp/fzf-XXXXXX.tar.gz)
    curl -fsSL "https://github.com/junegunn/fzf/releases/download/v${_ver}/fzf-${_ver}-linux_${_arch}.tar.gz" -o "$_tmp"
    tar -xz -C /tmp -f "$_tmp"
    sudo install -m 755 /tmp/fzf /usr/local/bin/fzf
    rm -f "$_tmp" /tmp/fzf
fi

# zoxide
if has zoxide; then
    skip zoxide
elif [ "$OS" = "darwin" ]; then
    brew install zoxide
else
    _ver=$(gh_latest ajeetdsouza/zoxide)
    _arch=$(uname -m)
    _tmp=$(mktemp /tmp/zoxide-XXXXXX.tar.gz)
    curl -fsSL "https://github.com/ajeetdsouza/zoxide/releases/download/v${_ver}/zoxide-${_ver}-${_arch}-unknown-linux-musl.tar.gz" -o "$_tmp"
    tar -xz -C /tmp -f "$_tmp"
    sudo install -m 755 /tmp/zoxide /usr/local/bin/zoxide
    rm -f "$_tmp" /tmp/zoxide
fi

# bat
if has bat || has batcat; then
    skip bat
elif [ "$OS" = "darwin" ]; then
    brew install bat
else
    _ver=$(gh_latest sharkdp/bat)
    _arch=$(uname -m)
    _target="unknown-linux-musl"
    [[ "$_arch" == "aarch64" ]] && _target="unknown-linux-gnu"
    _tmp=$(mktemp /tmp/bat-XXXXXX.tar.gz)
    curl -fsSL "https://github.com/sharkdp/bat/releases/download/v${_ver}/bat-v${_ver}-${_arch}-${_target}.tar.gz" -o "$_tmp"
    tar -xz -C /tmp -f "$_tmp"
    sudo install -m 755 /tmp/bat-*/bat /usr/local/bin/bat
    rm -rf /tmp/bat-*/ "$_tmp"
fi

# eza
if has eza; then
    skip eza
elif [ "$OS" = "darwin" ]; then
    brew install eza
elif [ "$IS_DEBIAN" = "true" ]; then
    sudo mkdir -p /etc/apt/keyrings
    wget -qO- https://raw.githubusercontent.com/eza-community/eza/main/deb.asc \
        | sudo gpg --dearmor -o /etc/apt/keyrings/gierens.gpg
    echo "deb [signed-by=/etc/apt/keyrings/gierens.gpg] http://deb.gierens.de stable main" \
        | sudo tee /etc/apt/sources.list.d/gierens.list
    sudo apt-get update -qq && sudo apt-get install -y eza
elif [ "$IS_RHEL" = "true" ]; then
    sudo dnf install -y eza 2>/dev/null || {
        _ver=$(gh_latest eza-community/eza)
        _arch=$(uname -m)
        _tmp=$(mktemp /tmp/eza-XXXXXX.tar.gz)
        curl -fsSL "https://github.com/eza-community/eza/releases/download/v${_ver}/eza_${_arch}-unknown-linux-gnu.tar.gz" -o "$_tmp"
        tar -xz -C /tmp -f "$_tmp"
        sudo install -m 755 /tmp/eza /usr/local/bin/eza
        rm -f "$_tmp" /tmp/eza
    }
fi

{{ end -}}

# ── top tools (htop + btop) ───────────────────────────────────────────────────
{{ if .installTopTools -}}
echo "── top tools ──"
has htop && skip htop || { pkg_update; pkg_install htop htop htop; }
if has btop; then
    skip btop
elif [ "$OS" = "darwin" ]; then
    brew install btop
elif [ "$IS_DEBIAN" = "true" ]; then
    pkg_update
    sudo apt-get install -y btop 2>/dev/null || {
        _ver=$(gh_latest aristocratos/btop)
        _arch=$(uname -m | sed 's/x86_64/x86_64/;s/aarch64/aarch64/')
        _tmp=$(mktemp /tmp/btop-XXXXXX.tbz)
        curl -fsSL "https://github.com/aristocratos/btop/releases/download/v${_ver}/btop-${_arch}-linux-musl.tbz" -o "$_tmp"
        tar -xj -C /tmp -f "$_tmp"
        sudo make -C /tmp/btop install PREFIX=/usr/local
        rm -rf /tmp/btop "$_tmp"
    }
elif [ "$IS_RHEL" = "true" ]; then
    sudo dnf install -y btop 2>/dev/null || {
        _ver=$(gh_latest aristocratos/btop)
        _arch=$(uname -m | sed 's/x86_64/x86_64/;s/aarch64/aarch64/')
        _tmp=$(mktemp /tmp/btop-XXXXXX.tbz)
        curl -fsSL "https://github.com/aristocratos/btop/releases/download/v${_ver}/btop-${_arch}-linux-musl.tbz" -o "$_tmp"
        tar -xj -C /tmp -f "$_tmp"
        sudo make -C /tmp/btop install PREFIX=/usr/local
        rm -rf /tmp/btop "$_tmp"
    }
fi
{{ end -}}

# ── mise ──────────────────────────────────────────────────────────────────────
{{ if .installMise -}}
echo "── mise ──"
if has mise; then
    skip mise
else
    curl -fsSL https://mise.run | sh
    echo "💡 Add mise to your PATH: eval \"\$(~/.local/bin/mise activate zsh)\""
fi
{{ end -}}

# ── tmux ──────────────────────────────────────────────────────────────────────
{{ if .installTmux -}}
echo "── tmux ──"
has tmux && skip tmux || { pkg_update; pkg_install tmux tmux tmux; }
{{ end -}}

# ── lazygit ───────────────────────────────────────────────────────────────────
{{ if .installLazygit -}}
echo "── lazygit ──"
if has lazygit; then
    skip lazygit
elif [ "$OS" = "darwin" ]; then
    brew install lazygit
else
    _ver=$(gh_latest jesseduffield/lazygit)
    _arch=$(uname -m | sed 's/aarch64/arm64/')
    _tmp=$(mktemp /tmp/lazygit-XXXXXX.tar.gz)
    curl -fsSL "https://github.com/jesseduffield/lazygit/releases/download/v${_ver}/lazygit_${_ver}_Linux_${_arch}.tar.gz" -o "$_tmp"
    tar -xz -C /tmp -f "$_tmp"
    sudo install -m 755 /tmp/lazygit /usr/local/bin/lazygit
    rm -f "$_tmp" /tmp/lazygit
fi
{{ end -}}

# ── neovim + ripgrep + fd-find ────────────────────────────────────────────────
{{ if .installNeovim -}}
echo "── neovim + ripgrep + fd ──"
if has nvim; then
    skip neovim
elif [ "$OS" = "darwin" ]; then
    brew install neovim
else
    _nvim_arch=$(uname -m)
    _nvim_tmp=$(mktemp /tmp/nvim-XXXXXX.tar.gz)
    curl -fsSL "https://github.com/neovim/neovim/releases/latest/download/nvim-linux-${_nvim_arch}.tar.gz" -o "$_nvim_tmp"
    sudo tar -xz -C /opt -f "$_nvim_tmp"
    sudo ln -sf "/opt/nvim-linux-${_nvim_arch}/bin/nvim" /usr/local/bin/nvim
    rm -f "$_nvim_tmp"
fi
if has rg; then
    skip ripgrep
elif [ "$OS" = "darwin" ]; then
    brew install ripgrep
else
    _ver=$(gh_latest BurntSushi/ripgrep)
    _arch=$(uname -m)
    _target="unknown-linux-musl"
    [[ "$_arch" == "aarch64" ]] && _target="unknown-linux-gnu"
    _tmp=$(mktemp /tmp/rg-XXXXXX.tar.gz)
    curl -fsSL "https://github.com/BurntSushi/ripgrep/releases/download/${_ver}/ripgrep-${_ver}-${_arch}-${_target}.tar.gz" -o "$_tmp"
    tar -xz -C /tmp -f "$_tmp"
    sudo install -m 755 /tmp/ripgrep-*/rg /usr/local/bin/rg
    rm -rf /tmp/ripgrep-*/ "$_tmp"
fi
if has fd || has fdfind; then
    skip fd-find
elif [ "$OS" = "darwin" ]; then
    brew install fd
else
    _ver=$(gh_latest sharkdp/fd)
    _arch=$(uname -m)
    _tmp=$(mktemp /tmp/fd-XXXXXX.tar.gz)
    curl -fsSL "https://github.com/sharkdp/fd/releases/download/v${_ver}/fd-v${_ver}-${_arch}-unknown-linux-musl.tar.gz" -o "$_tmp"
    tar -xz -C /tmp -f "$_tmp"
    sudo install -m 755 /tmp/fd-*/fd /usr/local/bin/fd
    rm -rf /tmp/fd-*/ "$_tmp"
fi
{{ end -}}

# ── uv ────────────────────────────────────────────────────────────────────────
{{ if .installUv -}}
echo "── uv ──"
if has uv; then
    skip uv
else
    curl -fsSL https://astral.sh/uv/install.sh | sh
fi
{{ end -}}

# ── ranger ────────────────────────────────────────────────────────────────────
{{ if .installRanger -}}
echo "── ranger ──"
has ranger && skip ranger || { pkg_update; pkg_install ranger ranger ranger; }
{{ end -}}

# ── sops ──────────────────────────────────────────────────────────────────────
{{ if .installSops -}}
echo "── sops ──"
if has sops; then
    skip sops
elif [ "$OS" = "darwin" ]; then
    brew install sops
else
    _ver=$(gh_latest getsops/sops)
    _arch=$(uname -m | sed 's/x86_64/amd64/;s/aarch64/arm64/')
    if [ "$IS_DEBIAN" = "true" ]; then
        curl -fsSL "https://github.com/getsops/sops/releases/download/v${_ver}/sops_${_ver}_${_arch}.deb" -o /tmp/sops.deb
        sudo dpkg -i /tmp/sops.deb && rm /tmp/sops.deb
    else
        curl -fsSL "https://github.com/getsops/sops/releases/download/v${_ver}/sops-v${_ver}.linux.${_arch}" \
            -o /tmp/sops
        sudo install -m 755 /tmp/sops /usr/local/bin/sops && rm /tmp/sops
    fi
fi
{{ end -}}

# ── wezterm (macOS only) ──────────────────────────────────────────────────────
{{ if and .installWezterm (eq .chezmoi.os "darwin") -}}
echo "── wezterm ──"
if has wezterm || [ -d "/Applications/WezTerm.app" ]; then
    skip wezterm
else
    brew install --cask wezterm
fi
{{ end -}}

# ── karabiner-elements (macOS only) ──────────────────────────────────────────
{{ if and .installKarabiner (eq .chezmoi.os "darwin") -}}
echo "── karabiner-elements ──"
if [ -d "/Applications/Karabiner-Elements.app" ]; then
    skip karabiner-elements
else
    brew install --cask karabiner-elements
fi
{{ end -}}

echo ""
echo "✅ Tool installation complete."
