{
  "title": "1. Capslock & right_command to hyper + hjkl",
  "rules": [
    {
      "description": "caps_lock to hyper(⌘⌥⌃⇧), ⎋ if pressed alone",
      "manipulators": [
        {
          "type": "basic",
          "from": { "key_code": "caps_lock" },
          "to": [ { "key_code": "right_option", "modifiers": [ "right_shift", "right_control", "right_command" ] } ],
          "to_if_alone": [ { "key_code": "escape" } ],
          "conditions": [ { "type": "device_unless", "identifiers": [ { "vendor_id": 7504, "product_id": 24926 } ] } ]
        }
      ]
    },
    {
      "description": "hyper + [h j k l y o] to [← ↓ ↑ → Home End]",
      "manipulators": [
        {
          "type": "basic",
          "from": { "key_code": "h", "modifiers": { "mandatory": [ "command", "shift", "option", "control" ] } },
          "to": { "key_code": "left_arrow" }
        },
        {
          "type": "basic",
          "from": { "key_code": "j", "modifiers": { "mandatory": [ "command", "shift", "option", "control" ] } },
          "to": { "key_code": "down_arrow" }
        },
        {
          "type": "basic",
          "from": { "key_code": "k", "modifiers": { "mandatory": [ "command", "shift", "option", "control" ] } },
          "to": { "key_code": "up_arrow" }
        },
        {
          "type": "basic",
          "from": { "key_code": "l", "modifiers": { "mandatory": [ "command", "shift", "option", "control" ] } },
          "to": { "key_code": "right_arrow" }
        },
        {
          "type": "basic",
          "from": { "key_code": "y", "modifiers": { "mandatory": [ "command", "shift", "option", "control" ] } },
          "to": { "key_code": "left_arrow", "modifiers": [ "command" ] }
        },
        {
          "type": "basic",
          "from": { "key_code": "o", "modifiers": { "mandatory": [ "command", "shift", "option", "control" ] } },
          "to": { "key_code": "right_arrow", "modifiers": [ "command" ] }
        },
        {
          "type": "basic",
          "from": { "key_code": "home" },
          "to": { "key_code": "left_arrow", "modifiers": [ "command" ] }
        },
        {
          "type": "basic",
          "from": { "key_code": "end" },
          "to": { "key_code": "right_arrow", "modifiers": [ "command" ] }
        }
      ]
    },
    {
      "description": "hyper + [n m ␣] to [⌫ ⌦ ↵]",
      "manipulators": [
        {
          "type": "basic",
          "from": { "key_code": "n", "modifiers": { "mandatory": [ "command", "shift", "option", "control" ] } },
          "to": { "key_code": "delete_or_backspace" }
        },
        {
          "type": "basic",
          "from": { "key_code": "m", "modifiers": { "mandatory": [ "command", "shift", "option", "control" ] } },
          "to": { "key_code": "delete_forward" }
        },
        {
          "type": "basic",
          "from": { "key_code": "spacebar", "modifiers": { "mandatory": [ "command", "shift", "option", "control" ] } },
          "to": { "key_code": "return_or_enter" }
        }
      ]
    },
    {
      "description": "Disable hyper+, hyper+.",
      "manipulators": [
        {
          "type": "basic",
          "from": { "key_code": "comma", "modifiers": { "mandatory": [ "command", "shift", "option", "control" ] } }
        },
        {
          "type": "basic",
          "from": { "key_code": "period", "modifiers": { "mandatory": [ "command", "shift", "option", "control" ] } }
        }
      ]
    }
  ]
}
